#Ce fichier utilise l'action officielle PMD, configure le jeu de règles "errorprone" et définit un seuil de tolérance (threshold).

name: PMD Analysis

on:
  push:
    branches: [ "main", "master" ]
  pull_request:
    branches: [ "main", "master" ]

permissions:
  contents: read
  security-events: write # Requis pour publier les alertes dans l'onglet Security

jobs:
  pmd-analysis:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up JDK 24
        uses: actions/setup-java@v4
        with:
          java-version: '24'
          distribution: 'temurin'

      # Point 1 & 2 : Exécution de PMD avec règles errorprone et threshold
      - name: Run PMD
        id: pmd
        uses: pmd/pmd-github-action@v2
        with:
          rulesets: 'category/java/errorprone.xml'
          # Point 2 : Faire échouer le workflow si plus de 0 violation (on  met  5, 10 selon le besoin)
          analyzeModifiedFilesOnly: false
          createIntermediateSarif: true
          # Pour faire échouer le build si des violations sont trouvées :
          failOnViolation: true 

      # Publication du rapport (Workflow Summary)
      - name: Upload SARIF file
        if: always()
        uses: github/codeql-action/upload-sarif@v3
        with:
          sarif_file: pmd-results.sarif
